{
  "info": {
    "name": "Production Ready API - Auth (better-auth)",
    "description": "Sign up + sign in (login) requests for the better-auth email/password flow, plus a protected user route to confirm the session cookie works.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Sign Up (create user)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Origin", "value": "{{origin}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Test User\",\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/sign-up/email",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "sign-up", "email"]
        },
        "description": "Creates a user via better-auth. Run this once before Login, or skip if the user already exists."
      },
      "response": []
    },
    {
      "name": "Sign In (login)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// better-auth also returns the session token in the JSON body;",
              "// stash it in case you need Bearer auth instead of the cookie jar.",
              "if (pm.response.code === 200) {",
              "    const json = pm.response.json();",
              "    if (json.token) {",
              "        pm.collectionVariables.set('sessionToken', json.token);",
              "    }",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Origin", "value": "{{origin}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"{{userEmail}}\",\n  \"password\": \"{{userPassword}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/auth/sign-in/email",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "sign-in", "email"]
        },
        "description": "Logs the user in. better-auth sets a `better-auth.session_token` cookie on success (requires Postman's cookie jar, enabled by default)."
      },
      "response": []
    },
    {
      "name": "Get Current User (via /user/:id, sanity check)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/user/{{userId}}",
          "host": ["{{baseUrl}}"],
          "path": ["user", "{{userId}}"]
        },
        "description": "Not session-protected in code, but useful to confirm the API + Prisma are reachable after login. Set {{userId}} from the sign-up/sign-in response."
      },
      "response": []
    },
    {
      "name": "List Users (ADMIN only, requires session cookie)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/user/all",
          "host": ["{{baseUrl}}"],
          "path": ["user", "all"]
        },
        "description": "Guarded by @Roles(['ADMIN']). Will 403 unless the logged-in session belongs to an ADMIN user. Relies on the session cookie set by the Sign In request."
      },
      "response": []
    },
    {
      "name": "Sign Out (logout)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Origin", "value": "{{origin}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/auth/sign-out",
          "host": ["{{baseUrl}}"],
          "path": ["api", "auth", "sign-out"]
        }
      },
      "response": []
    }
  ],
  "variable": [
    { "key": "sessionToken", "value": "" },
    { "key": "userId", "value": "" }
  ]
}
