# Copy this file to .env and fill in real values.
# All variables are validated at startup — see src/config/env.validation.ts.

# development | production | test (optional, defaults to "development")
NODE_ENV=development

# HTTP port the app listens on (optional, defaults to 3000)
PORT=3000

# PostgreSQL connection string (required)
DATABASE_URL="postgres://user:password@localhost:5432/database"

# Better Auth secret, min 32 characters (required)
BETTER_AUTH_SECRET="replace-with-a-random-32-plus-character-secret"

# Base URL Better Auth uses for callbacks/redirects (required)
BETTER_AUTH_URL="http://localhost:3000"

# Arcjet site key (required)
ARCJET_KEY="ajkey_your_key_here"

# development | production | test (optional, defaults to "development")
# Read directly by @arcjet/env, not by application code.
ARCJET_ENV=development

# LIVE | DRY_RUN (optional, defaults to "LIVE")
# Read directly by @arcjet/env, not by application code.
ARCJET_MODE=LIVE
